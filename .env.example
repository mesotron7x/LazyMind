# Mirror configuration
# By default, all mirrors point to Chinese domestic sources.
# To switch to international sources, uncomment and set the values below.

# Docker Hub mirror prefix (trailing slash required)
# Domestic (default): docker.m.daocloud.io/library/
# International:      (empty string)
#DOCKER_MIRROR=

# PyPI mirror
# Domestic (default): https://mirrors.aliyun.com/pypi/simple
# International:      https://pypi.org/simple
#PIP_INDEX_URL=https://pypi.org/simple

# Go module proxy
# Domestic (default): https://goproxy.cn,direct
# International:      https://proxy.golang.org,direct
#GOPROXY=https://proxy.golang.org,direct

# APT mirror (used inside Python/Go Docker images)
# Domestic (default): http://mirrors.aliyun.com/debian
# International:      http://deb.debian.org/debian
#APT_MIRROR=http://deb.debian.org/debian
#APT_SECURITY_MIRROR=http://security.debian.org

# pip timeout / retry tuning
#PIP_DEFAULT_TIMEOUT=300
#PIP_RETRIES=10
